# public RPC used for reads, fee data, and local session-key signing flows
REACT_APP_RPC_URL=https://rpc.ankr.com/eth_sepolia/API_KEY

# address of deployed SmartAccountFactory
REACT_APP_FACTORY_ADDRESS=

# address of deployed Counter demo contract
REACT_APP_COUNTER_ADDRESS=

# bundler endpoint for sending UserOps (e.g. Pimlico, Alchemy, Rundler)
REACT_APP_BUNDLER_URL=https://api.pimlico.io/v2/11155111/rpc?apikey=

# optional entrypoint override, defaults to v0.7 on Sepolia
REACT_APP_ENTRY_POINT_ADDRESS=0x0000000071727De22E5E9d8BAf0edAc6f37da032

# indexer API base URL
REACT_APP_INDEXER_URL=http://localhost:3001

# optional explicit websocket URL for the live feed
REACT_APP_INDEXER_WS_URL=ws://localhost:3001

# optional explorer base URL override for row click-through
# example: https://sepolia.etherscan.io
REACT_APP_ETHERSCAN_BASE_URL=https://etherscan.io
